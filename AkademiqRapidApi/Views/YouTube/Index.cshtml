@model AkademiqRapidApi.Models.YouTubeViewModel.Rootobject
@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>YouTube MP3</title>
</head>
<body>
    <h2>YouTube MP3 Çevirici</h2>

    <form method="get">
        <input type="text" name="id" placeholder="YouTube mp3 çeviri için video ID gir">
        <button type="submit">
            MP3 Getir
        </button>
    </form>

    @if (Model != null)
        {
            <p>Başlık : @Model.title</p>
            <p>Süre : @Model.duration</p>
            <p>Durum : @Model.status</p>
            <p>Boyut : @Model.filesize</p>

            <p>
                Link : <a href="@Model.link" target="_blank">MP3 İndir</a>
            </p>

            <p>Mesaj : @Model.msg</p>
        }
    </body>
</html>
