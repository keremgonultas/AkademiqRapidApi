@model List<AkademiqRapidApi.Models.GasPriceItem>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Akaryakıt Fiyatları";
}

<div class="max-w-[1400px] mx-auto pt-6 px-6 lg:px-8 pb-12">
    <header class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-teal-100 text-teal-600 flex items-center justify-center shadow-inner">
                    <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">local_gas_station</span>
                </div>
                <h1 class="text-4xl font-black text-slate-900 tracking-tighter mb-1">Akaryakıt Fiyatları</h1>
            </div>
            <p class="text-slate-500 font-medium text-lg mt-1">Avrupa ve Dünya geneli güncel yakıt fiyatları (Euro bazında)</p>
        </div>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        @if (Model != null && Model.Count > 0)
        {
            
            var validCountries = Model.Where(x => !string.IsNullOrWhiteSpace(x.country) && x.gasoline != "0,000").ToList();

            @foreach (var item in validCountries)
            {
                <div class="bg-white rounded-[2rem] border border-slate-100 shadow-sm p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300 flex flex-col">
                    <div class="flex items-center gap-3 mb-6 pb-4 border-b border-slate-50">
                        <div class="w-10 h-10 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 font-black text-sm uppercase">
                            @item.country.Substring(0, 2)
                        </div>
                        <h3 class="font-black text-lg text-slate-800 tracking-tight">@item.country</h3>
                    </div>

                    <div class="flex flex-col gap-4">
                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2 text-slate-500">
                                <span class="material-symbols-outlined text-lg">directions_car</span>
                                <span class="text-sm font-semibold">Benzin</span>
                            </div>
                            <div class="font-black text-slate-900">
                                @(item.gasoline == "-" ? "N/A" : $"€{item.gasoline}")
                            </div>
                        </div>

                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2 text-slate-500">
                                <span class="material-symbols-outlined text-lg">local_shipping</span>
                                <span class="text-sm font-semibold">Dizel</span>
                            </div>
                            <div class="font-black text-slate-900">
                                @(item.diesel == "-" ? "N/A" : $"€{item.diesel}")
                            </div>
                        </div>

                        <div class="flex items-center justify-between">
                            <div class="flex items-center gap-2 text-slate-500">
                                <span class="material-symbols-outlined text-lg">propane</span>
                                <span class="text-sm font-semibold">LPG</span>
                            </div>
                            <div class="font-black text-slate-900">
                                @(item.lpg == "-" ? "N/A" : $"€{item.lpg}")
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-span-full bg-white rounded-[2rem] border border-slate-100 p-12 flex flex-col items-center justify-center text-center shadow-sm">
                <span class="material-symbols-outlined text-6xl text-slate-200 mb-4">oil_barrel</span>
                <h3 class="text-xl font-bold text-slate-800 mb-2">Veri Yüklenemedi</h3>
                <p class="text-slate-500 max-w-md">Akaryakıt verileri şu an çekilemiyor. Lütfen API bağlantınızı kontrol edin veya daha sonra tekrar deneyin.</p>
            </div>
        }
    </div>
</div>