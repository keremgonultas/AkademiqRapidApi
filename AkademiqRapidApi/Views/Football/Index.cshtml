@model List<AkademiqRapidApi.Models.FootballViewModel.TeamStanding>

<div class="container mt-5">
    <h2 class="mb-4">🏆 Süper Lig Puan Durumu</h2>

    <div class="table-responsive shadow-sm rounded">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-dark">
                <tr class="text-center">
                    <th>Sıra</th>
                    <th class="text-start">Takım</th>
                    <th>O</th>
                    <th>G</th>
                    <th>B</th>
                    <th>M</th>
                    <th>A</th>
                    <th>Y</th>
                    <th>AV</th>
                    <th>P</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null)
                {
                    @foreach (var item in Model)
                    {
                        <tr class="text-center">
                            <td><strong>@item.stats.rank</strong></td>
                            <td class="text-start">
                                <img src="@item.team.logo" alt="@item.team.name" style="width: 30px; height: 30px; object-fit: contain;" class="me-2" />
                                <span class="fw-bold">@item.team.name</span>
                            </td>
                            <td>@item.stats.gamesPlayed</td>
                            <td>@item.stats.wins</td>
                            <td>@item.stats.ties</td>
                            <td>@item.stats.losses</td>
                            <td>@item.stats.goalsFor</td>
                            <td>@item.stats.goalsAgainst</td>
                            
                            <td class="@(item.stats.goalDifference > 0 ? "text-success" : item.stats.goalDifference < 0 ? "text-danger" : "")">
                                @(item.stats.goalDifference > 0 ? "+" + item.stats.goalDifference : item.stats.goalDifference)
                            </td>
                            
                            <td><strong class="fs-5">@item.stats.points</strong></td>
                        </tr>
                    }
                }
                else
                {
                    <tr>
                        <td colspan="10" class="text-center text-muted py-4">Puan durumu verisi çekilemedi.</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>