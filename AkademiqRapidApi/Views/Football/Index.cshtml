@model List<AkademiqRapidApi.Models.FootballViewModel.TeamStanding>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Lig Tablosu";
}

<div class="max-w-[1400px] mx-auto pt-6 px-6 lg:px-8 pb-12">
    <header class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <h1 class="text-4xl font-black text-slate-900 tracking-tighter mb-1">Trendyol Süper Lig</h1>
            <p class="text-slate-500 font-medium text-lg">Güncel Puan Durumu</p>
        </div>
        <div class="flex gap-2">
            <div class="px-4 py-2 bg-white rounded-xl flex items-center gap-2 text-sm font-semibold text-slate-600 shadow-sm border border-slate-200">
                <span class="material-symbols-outlined text-sm text-blue-500">calendar_month</span>
                Güncel Sezon
            </div>
        </div>
    </header>

    <div class="flex flex-col xl:flex-row gap-8 items-start">
        
        <div class="flex-1 w-full min-w-0">
            <div class="bg-white rounded-[1.5rem] shadow-sm border border-slate-200 overflow-hidden">
                <div class="overflow-x-auto">
                    <table class="w-full text-left border-collapse whitespace-nowrap">
                        <thead>
                            <tr class="bg-slate-900 text-white">
                                <th class="py-4 px-6 font-bold text-xs uppercase tracking-widest">Sıra</th>
                                <th class="py-4 px-6 font-bold text-xs uppercase tracking-widest">Takım</th>
                                <th class="py-4 px-4 font-bold text-xs uppercase tracking-widest text-center">O</th>
                                <th class="py-4 px-4 font-bold text-xs uppercase tracking-widest text-center">G</th>
                                <th class="py-4 px-4 font-bold text-xs uppercase tracking-widest text-center">B</th>
                                <th class="py-4 px-4 font-bold text-xs uppercase tracking-widest text-center">M</th>
                                <th class="py-4 px-4 font-bold text-xs uppercase tracking-widest text-center">A</th>
                                <th class="py-4 px-4 font-bold text-xs uppercase tracking-widest text-center">Y</th>
                                <th class="py-4 px-4 font-bold text-xs uppercase tracking-widest text-center">AV</th>
                                <th class="py-4 px-6 font-bold text-xs uppercase tracking-widest text-center">P</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-slate-100">
                            @if (Model != null && Model.Any())
                            {
                                @foreach (var item in Model)
                                {
                                    string rankBgClass = "bg-slate-100 text-slate-500";
                                    string shadowClass = "";

                                    if (item.stats.rank == 1)
                                    {
                                        rankBgClass = "bg-emerald-500 text-white";
                                        shadowClass = "shadow-sm shadow-emerald-500/20";
                                    }
                                    else if (item.stats.rank <= 3) { rankBgClass = "bg-blue-50 text-blue-700"; }
                                    else if (item.stats.rank >= 17) { rankBgClass = "bg-rose-500 text-white"; }

                                    string avColor = "text-slate-500";
                                    string avPrefix = "";
                                    if (item.stats.goalDifference > 0) { avColor = "text-emerald-600"; avPrefix = "+"; }
                                    else if (item.stats.goalDifference < 0) { avColor = "text-rose-500"; }

                                    <tr class="group hover:bg-slate-50 transition-all cursor-pointer">
                                        <td class="py-3 px-6">
                                            <span class="inline-flex items-center justify-center w-8 h-8 rounded-full @rankBgClass font-bold text-sm @shadowClass">
                                                @item.stats.rank
                                            </span>
                                        </td>
                                        <td class="py-3 px-6">
                                            <div class="flex items-center gap-4">
                                                <div class="w-10 h-10 rounded-xl border border-slate-200 bg-white p-1.5 flex items-center justify-center group-hover:scale-110 transition-transform shrink-0">
                                                    <img alt="@item.team.name Logo" class="w-full h-full object-contain" src="@item.team.logo" />
                                                </div>
                                                <span class="font-bold text-slate-800">@item.team.name</span>
                                            </div>
                                        </td>
                                        <td class="py-3 px-4 text-center font-medium text-slate-500">@item.stats.gamesPlayed</td>
                                        <td class="py-3 px-4 text-center font-medium text-slate-500">@item.stats.wins</td>
                                        <td class="py-3 px-4 text-center font-medium text-slate-500">@item.stats.ties</td>
                                        <td class="py-3 px-4 text-center font-medium text-slate-500">@item.stats.losses</td>
                                        <td class="py-3 px-4 text-center font-medium text-slate-500">@item.stats.goalsFor</td>
                                        <td class="py-3 px-4 text-center font-medium text-slate-500">@item.stats.goalsAgainst</td>
                                        <td class="py-3 px-4 text-center font-bold @avColor">@(avPrefix)@item.stats.goalDifference</td>
                                        <td class="py-3 px-6 text-center bg-slate-50/50">
                                            <span class="text-xl font-black text-slate-900">@item.stats.points</span>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="10" class="text-center py-12 text-slate-500 font-medium">
                                        <span class="material-symbols-outlined text-4xl block mb-2 text-slate-300">sentiment_dissatisfied</span>
                                        Puan durumu verisi şu an çekilemiyor.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="w-full xl:w-80 shrink-0">
            @if (Model != null && Model.Any())
            {
                int totalGoals = Model.Sum(x => x.stats.goalsFor);
                int totalGamesPlayed = Model.Sum(x => x.stats.gamesPlayed) / 2;
                double goalsPerMatch = totalGamesPlayed > 0 ? Math.Round((double)totalGoals / totalGamesPlayed, 2) : 0;
                
                var bestOffense = Model.OrderByDescending(x => x.stats.goalsFor).FirstOrDefault();
                var bestDefense = Model.OrderBy(x => x.stats.goalsAgainst).FirstOrDefault();

                <div class="bg-slate-900 text-white p-6 md:p-8 rounded-[2rem] shadow-xl relative overflow-hidden">
                    <div class="relative z-10">
                        <h3 class="text-xs uppercase tracking-widest font-bold text-white/50 mb-6">Lig İstatistikleri</h3>
                        <div class="space-y-6">
                            
                            <div class="flex items-center justify-between gap-2">
                                <span class="text-sm font-medium text-white/80 shrink-0">Toplam Gol</span>
                                <span class="text-2xl md:text-3xl font-black">@totalGoals</span>
                            </div>
                            
                            <div class="flex items-center justify-between gap-2">
                                <span class="text-sm font-medium text-white/80 shrink-0">Maç Başına</span>
                                <span class="text-xl font-bold text-emerald-400">@goalsPerMatch</span>
                            </div>

                            <div class="w-full h-px bg-white/10 my-4"></div>

                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-medium text-white/50">En Golcü Takım</span>
                                <div class="flex items-center justify-between gap-2">
                                    <span class="text-sm font-bold truncate">@(bestOffense?.team.name ?? "-")</span>
                                    <span class="text-sm font-bold text-emerald-400 shrink-0">@(bestOffense?.stats.goalsFor ?? 0) Gol</span>
                                </div>
                            </div>

                            <div class="flex flex-col gap-1">
                                <span class="text-xs font-medium text-white/50">En İyi Savunma</span>
                                <div class="flex items-center justify-between gap-2">
                                    <span class="text-sm font-bold truncate">@(bestDefense?.team.name ?? "-")</span>
                                    <span class="text-sm font-bold text-sky-400 shrink-0">@(bestDefense?.stats.goalsAgainst ?? 0) Yedi</span>
                                </div>
                            </div>

                        </div>
                    </div>
                    <div class="absolute -right-4 -bottom-4 opacity-[0.03] pointer-events-none">
                        <span class="material-symbols-outlined text-[140px]" style="font-variation-settings: 'FILL' 1;">analytics</span>
                    </div>
                </div>
            }
        </div>
    </div>
</div>