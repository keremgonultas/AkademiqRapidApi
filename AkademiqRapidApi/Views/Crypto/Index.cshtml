@model List<AkademiqRapidApi.Models.CryptoCoin>
@{
    Layout = "_Layout";
    ViewData["Title"] = "Kripto Piyasası";
}

<div class="max-w-7xl mx-auto p-6 lg:p-8">
    <header class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-amber-100 text-amber-600 flex items-center justify-center shadow-inner">
                    <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">currency_bitcoin</span>
                </div>
                <h1 class="text-3xl font-black tracking-tighter text-slate-900">Kripto Piyasası</h1>
            </div>
            <p class="text-slate-500 font-medium mt-1">Anlık kripto para birimleri ve piyasa değişimleri</p>
        </div>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6">
        @if (Model != null && Model.Count > 0)
        {
            @foreach (var coin in Model)
            {
                var priceParsed = double.TryParse(coin.price, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out double p) ? p : 0;
                var formattedPrice = priceParsed < 0.01 ? priceParsed.ToString("0.00000", System.Globalization.CultureInfo.InvariantCulture) : priceParsed.ToString("0.00", System.Globalization.CultureInfo.InvariantCulture);
                var changeParsed = double.TryParse(coin.change, System.Globalization.NumberStyles.Float, System.Globalization.CultureInfo.InvariantCulture, out double c) ? c : 0;
                var isPositive = changeParsed >= 0;

                
                var coinColor = !string.IsNullOrEmpty(coin.color) ? coin.color.Replace("#", "") : "1e293b"; 
                var safeName = !string.IsNullOrEmpty(coin.symbol) ? coin.symbol.Replace("$", "").Replace(" ", "+") : "C"; 

                <div class="bg-white rounded-[2rem] border border-slate-100 shadow-sm p-6 hover:shadow-xl hover:-translate-y-1 transition-all duration-300">
                    <div class="flex justify-between items-start mb-4">
                        <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full overflow-hidden bg-slate-50 border border-slate-100 flex items-center justify-center p-1.5">
                                <img src="@coin.iconUrl" alt="@coin.name" class="w-full h-full object-contain rounded-full"
                                     onerror="this.onerror=null; this.src='https://ui-avatars.com/api/?name=@safeName&background=@coinColor&color=fff&bold=true&font-size=0.4';" />
                            </div>
                            <div>
                                <h3 class="font-bold text-slate-900 leading-tight">@coin.name</h3>
                                <span class="text-xs font-semibold text-slate-400">@coin.symbol</span>
                            </div>
                        </div>
                        <span class="text-xs font-black text-slate-300">#@coin.rank</span>
                    </div>
                    
                    <div class="mt-4">
                        <div class="text-2xl font-black text-slate-900 tracking-tight">$@formattedPrice</div>
                        <div class="flex items-center gap-1 mt-1 @(isPositive ? "text-emerald-500" : "text-rose-500")">
                            <span class="material-symbols-outlined text-sm">@(isPositive ? "trending_up" : "trending_down")</span>
                            <span class="text-sm font-bold">@(isPositive ? "+" : "")@coin.change%</span>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-span-full bg-white rounded-[2rem] border border-slate-100 p-12 flex flex-col items-center justify-center text-center shadow-sm">
                <span class="material-symbols-outlined text-6xl text-slate-200 mb-4">currency_exchange</span>
                <h3 class="text-xl font-bold text-slate-800 mb-2">Veri Yüklenemedi</h3>
                <p class="text-slate-500 max-w-md">Kripto para verileri şu an çekilemiyor. Lütfen API bağlantınızı kontrol edin veya sayfayı yenileyin.</p>
            </div>
        }
    </div>
</div>