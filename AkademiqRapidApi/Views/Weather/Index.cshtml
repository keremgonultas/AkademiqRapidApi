@model AkademiqRapidApi.Models.WeatherViewModel

<div class="container mt-5">
    @if (Model != null && Model.location != null)
    {
        <h2 class="mb-4 text-info fw-bold">🌤️ Hava Durumu Paneli</h2>
        
        <div class="card shadow-sm mb-4 border-0 bg-light">
            <div class="card-body">
                <h4 class="card-title fw-bold">@Model.location.city, @Model.location.country</h4>
                <div class="row mt-3">
                    <div class="col-md-6">
                        <h1 class="display-4 fw-bold text-primary">@Model.current_observation.condition.temperature°C</h1>
                        <p class="fs-5 text-muted">@Model.current_observation.condition.text</p>
                    </div>
                    <div class="col-md-6 border-start">
                        <p class="mb-1"><strong>💧 Nem:</strong> %@Model.current_observation.atmosphere.humidity</p>
                        <p class="mb-1"><strong>💨 Rüzgar:</strong> @Model.current_observation.wind.speed km/s</p>
                        <p class="mb-1"><strong>🌅 Gün Doğumu:</strong> @Model.current_observation.astronomy.sunrise</p>
                        <p class="mb-0"><strong>🌇 Gün Batımı:</strong> @Model.current_observation.astronomy.sunset</p>
                    </div>
                </div>
            </div>
        </div>

        <h5 class="mb-3 fw-bold text-secondary">📅 Haftalık Tahmin</h5>
        <div class="row">
            @if (Model.forecasts != null)
            {
                @foreach (var day in Model.forecasts.Take(6)) // Ekrana sığması için ilk 6 günü alıyoruz
                {
                    <div class="col-md-2 mb-3">
                        <div class="card text-center shadow-sm border-0">
                            <div class="card-header bg-info text-white fw-bold">
                                @day.day
                            </div>
                            <div class="card-body p-2">
                                <p class="small text-muted mb-1 text-truncate" title="@day.text">@day.text</p>
                                <strong class="text-danger">@day.high°</strong> / <span class="text-primary">@day.low°</span>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="alert alert-warning">Hava durumu verileri şu an çekilemiyor. API ayarlarınızı kontrol edin.</div>
    }
</div>