@model AkademiqRapidApi.Models.WeatherViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Hava Durumu";
}

<div class="max-w-[1400px] mx-auto pt-6 px-6 lg:px-8 pb-12">
    <header class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-blue-100 text-blue-600 flex items-center justify-center shadow-inner">
                    <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">cloudy</span>
                </div>
                <h1 class="text-4xl font-black text-slate-900 tracking-tighter mb-1">Hava Durumu</h1>
            </div>
            <p class="text-slate-500 font-medium text-lg mt-1">@Model.location.city için anlık ve haftalık tahminler</p>
        </div>
    </header>

    @if (Model != null && Model.current_observation != null)
    {
        <div class="bg-gradient-to-br from-blue-500 to-indigo-600 rounded-[2.5rem] p-8 md:p-12 text-white shadow-2xl shadow-blue-500/30 relative overflow-hidden mb-10">
            <div class="relative z-10 flex flex-col md:flex-row justify-between items-center gap-8">
                <div class="text-center md:text-left">
                    <h2 class="text-6xl md:text-8xl font-black tracking-tighter mb-2">@Model.current_observation.condition.temperature°</h2>
                    <p class="text-xl md:text-2xl font-bold text-blue-100 uppercase tracking-widest">
                        @AkademiqRapidApi.Models.WeatherTranslator.TranslateCondition(Model.current_observation.condition.text)
                    </p>
                </div>
                
                <div class="grid grid-cols-2 gap-8 md:gap-16">
                    <div class="text-center">
                        <span class="material-symbols-outlined text-4xl mb-2 opacity-50">air</span>
                        <p class="text-xs font-black uppercase tracking-widest text-blue-200">Rüzgar</p>
                        <p class="text-xl font-bold">@Model.current_observation.wind.speed km/h</p>
                    </div>
                    <div class="text-center">
                        <span class="material-symbols-outlined text-4xl mb-2 opacity-50">humidity_percentage</span>
                        <p class="text-xs font-black uppercase tracking-widest text-blue-200">Nem</p>
                        <p class="text-xl font-bold">%@Model.current_observation.atmosphere.humidity</p>
                    </div>
                </div>
            </div>
            <span class="material-symbols-outlined absolute -right-12 -bottom-12 text-[250px] text-white opacity-10 pointer-events-none" style="font-variation-settings: 'FILL' 1;">partly_cloudy_day</span>
        </div>

        <h3 class="text-2xl font-black text-slate-800 mb-6 px-2">Haftalık Tahmin</h3>
        <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-7 gap-4">
            @foreach (var forecast in Model.forecasts)
            {
                <div class="bg-white rounded-3xl p-6 border border-slate-100 shadow-sm hover:shadow-md transition-all text-center group">
                    <p class="text-slate-400 font-bold text-sm uppercase tracking-widest mb-4">
                        @AkademiqRapidApi.Models.WeatherTranslator.TranslateDay(forecast.day)
                    </p>
                    
                    <div class="w-12 h-12 bg-slate-50 rounded-2xl mx-auto mb-4 flex items-center justify-center group-hover:bg-blue-50 transition-colors">
                        <span class="material-symbols-outlined text-blue-500">sunny</span>
                    </div>

                    <div class="flex flex-col gap-1 mb-4">
                        <span class="text-2xl font-black text-slate-900">@forecast.high°</span>
                        <span class="text-sm font-bold text-slate-400">@forecast.low°</span>
                    </div>

                    <p class="text-[10px] font-black uppercase tracking-tighter text-slate-400 leading-tight">
                        @AkademiqRapidApi.Models.WeatherTranslator.TranslateCondition(forecast.text)
                    </p>
                </div>
            }
        </div>
    }
</div>