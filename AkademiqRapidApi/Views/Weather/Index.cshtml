@model AkademiqRapidApi.Models.WeatherViewModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Hava Durumu";

    // AKILLI İKON SEÇİCİ: İngilizce hava durumu metnine göre uygun Google Material ikonunu döndürür
    string GetWeatherIcon(string condition)
    {
        if (string.IsNullOrEmpty(condition)) return "partly_cloudy_day";
        var c = condition.ToLower();
        if (c.Contains("sun") || c.Contains("clear")) return "sunny";
        if (c.Contains("rain") || c.Contains("shower") || c.Contains("drizzle")) return "rainy";
        if (c.Contains("storm") || c.Contains("thunder")) return "thunderstorm";
        if (c.Contains("snow") || c.Contains("ice")) return "cloudy_snowing";
        if (c.Contains("cloud") || c.Contains("overcast")) return "cloud";
        return "partly_cloudy_day";
    }
}

<div class="max-w-7xl mx-auto p-6 lg:p-8">
    
    @if (Model != null && Model.location != null && Model.current_observation != null)
    {
        <header class="mb-8 flex flex-col md:flex-row md:items-end justify-between gap-4">
            <div>
                <div class="flex items-center gap-3 mb-2">
                    <div class="w-12 h-12 rounded-2xl bg-sky-100 text-sky-600 flex items-center justify-center shadow-inner">
                        <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">routine</span>
                    </div>
                    <h1 class="text-3xl font-black tracking-tighter text-slate-900">Hava Durumu</h1>
                </div>
                <p class="text-slate-500 font-medium md:ml-15 mt-1">
                    <span class="font-bold text-slate-700">@Model.location.city, @Model.location.country</span> için anlık veriler ve tahminler
                </p>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 mb-10">
            
            <div class="lg:col-span-2 bg-gradient-to-br from-sky-400 to-blue-600 rounded-[2.5rem] p-8 md:p-10 text-white shadow-xl shadow-blue-500/20 relative overflow-hidden flex flex-col justify-between min-h-[300px]">
                <span class="material-symbols-outlined absolute -right-12 -bottom-12 text-[250px] text-white/10 select-none" style="font-variation-settings: 'FILL' 1;">
                    @GetWeatherIcon(Model.current_observation.condition.text)
                </span>
                
                <div class="relative z-10 flex flex-col h-full justify-between">
                    <div class="flex justify-between items-start">
                        <span class="px-4 py-1.5 rounded-full bg-white/20 backdrop-blur-md text-sm font-bold tracking-widest uppercase border border-white/20">
                            Şu An
                        </span>
                        <span class="material-symbols-outlined text-5xl" style="font-variation-settings: 'FILL' 1;">
                            @GetWeatherIcon(Model.current_observation.condition.text)
                        </span>
                    </div>
                    
                    <div class="mt-8">
                        <div class="text-8xl md:text-9xl font-black tracking-tighter drop-shadow-lg">
                            @Model.current_observation.condition.temperature°
                        </div>
                        <p class="text-2xl md:text-3xl font-semibold text-sky-50 mt-2 capitalize drop-shadow-md">
                            @Model.current_observation.condition.text
                        </p>
                    </div>
                </div>
            </div>

            <div class="bg-white rounded-[2.5rem] p-6 shadow-sm border border-slate-100 flex flex-col gap-4 justify-between">
                
                <div class="flex items-center gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-100 hover:bg-sky-50 transition-colors">
                    <div class="w-12 h-12 rounded-full bg-blue-100 text-blue-600 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined">humidity_percentage</span>
                    </div>
                    <div>
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-0.5">Nem Oranı</p>
                        <p class="text-xl font-black text-slate-800">%@Model.current_observation.atmosphere.humidity</p>
                    </div>
                </div>

                <div class="flex items-center gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-100 hover:bg-teal-50 transition-colors">
                    <div class="w-12 h-12 rounded-full bg-teal-100 text-teal-600 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined">air</span>
                    </div>
                    <div>
                        <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-0.5">Rüzgar Hızı</p>
                        <p class="text-xl font-black text-slate-800">@Model.current_observation.wind.speed <span class="text-sm font-semibold text-slate-500">km/s</span></p>
                    </div>
                </div>

                <div class="flex items-center gap-4 p-4 rounded-2xl bg-slate-50 border border-slate-100 hover:bg-amber-50 transition-colors">
                    <div class="w-12 h-12 rounded-full bg-amber-100 text-amber-600 flex items-center justify-center shrink-0">
                        <span class="material-symbols-outlined">wb_twilight</span>
                    </div>
                    <div class="flex-1 flex justify-between items-center pr-2">
                        <div>
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-0.5">Doğuş</p>
                            <p class="text-base font-black text-slate-800">@Model.current_observation.astronomy.sunrise</p>
                        </div>
                        <div class="h-8 w-px bg-slate-200 mx-2"></div>
                        <div class="text-right">
                            <p class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-0.5">Batış</p>
                            <p class="text-base font-black text-slate-800">@Model.current_observation.astronomy.sunset</p>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <h3 class="text-xl font-black text-slate-900 mb-6 flex items-center gap-2 px-2">
            <span class="material-symbols-outlined text-slate-400">calendar_month</span>
            Haftalık Tahmin
        </h3>
        
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
            @if (Model.forecasts != null)
            {
                @foreach (var day in Model.forecasts.Take(6))
                {
                    <div class="bg-white rounded-[1.5rem] p-5 shadow-sm border border-slate-100 flex flex-col items-center text-center hover:-translate-y-1.5 hover:shadow-md hover:border-sky-200 transition-all duration-300">
                        <span class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-4">@day.day</span>
                        
                        <div class="w-14 h-14 rounded-full bg-slate-50 flex items-center justify-center mb-4 text-sky-500">
                            <span class="material-symbols-outlined text-3xl" style="font-variation-settings: 'FILL' 1;">
                                @GetWeatherIcon(day.text)
                            </span>
                        </div>
                        
                        <p class="text-[11px] font-bold text-slate-500 mb-4 h-8 line-clamp-2 leading-tight" title="@day.text">
                            @day.text
                        </p>
                        
                        <div class="flex items-center gap-3 mt-auto bg-slate-50 px-3 py-1.5 rounded-xl border border-slate-100">
                            <span class="text-lg font-black text-rose-500">@day.high°</span>
                            <span class="text-slate-300 font-bold">/</span>
                            <span class="text-base font-bold text-sky-500">@day.low°</span>
                        </div>
                    </div>
                }
            }
        </div>
    }
    else
    {
        <div class="flex flex-col items-center justify-center py-24 bg-white rounded-[2rem] border border-slate-100 shadow-sm mt-8">
            <div class="w-24 h-24 mb-6 rounded-full bg-slate-50 flex items-center justify-center">
                <span class="material-symbols-outlined text-5xl text-slate-300">cloud_off</span>
            </div>
            <h3 class="text-xl font-bold text-slate-700 mb-2">Hava Durumu Yüklenemedi</h3>
            <p class="text-slate-500 text-center max-w-md">Şu an için hava durumu verilerine ulaşılamıyor. Lütfen API bağlantınızı ve kotalarınızı kontrol edin.</p>
        </div>
    }
</div>