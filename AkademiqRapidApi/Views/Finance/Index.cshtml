@model AkademiqRapidApi.Models.FinanceViewModel
@{
    ViewData["Title"] = "Finans Haberleri";
}

<div class="max-w-6xl mx-auto p-6 lg:p-8">
    <header class="mb-10 flex flex-col md:flex-row md:items-end justify-between gap-4">
        <div>
            <div class="flex items-center gap-3 mb-2">
                <div class="w-12 h-12 rounded-2xl bg-emerald-100 text-emerald-600 flex items-center justify-center shadow-inner">
                    <span class="material-symbols-outlined text-3xl">trending_up</span>
                </div>
                <h1 class="text-3xl font-black tracking-tighter text-slate-900">Finans Haberleri</h1>
            </div>
            <p class="text-slate-500 font-medium md:ml-15 mt-1">Teknoloji ve piyasa dünyasından son dakika gelişmeleri</p>
        </div>
    </header>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        @if (Model != null && Model.body != null && Model.body.Any())
        {
            @foreach (var news in Model.body)
            {
                <div class="bg-white rounded-[1.5rem] shadow-sm border border-slate-100 hover:shadow-md hover:-translate-y-1 transition-all duration-300 flex flex-col overflow-hidden relative group">
                    
                    <div class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-emerald-400 to-teal-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                    
                    <div class="p-6 md:p-8 flex flex-col flex-1">
                        <h5 class="text-lg font-bold text-slate-800 mb-3 line-clamp-2 leading-snug group-hover:text-emerald-600 transition-colors">
                            @news.title
                        </h5>
                        
                        <p class="text-sm text-slate-500 mb-6 line-clamp-3 flex-1 leading-relaxed">
                            @news.description
                        </p>
                        
                        <div class="mt-auto flex justify-between items-center pt-5 border-t border-slate-50">
                            
                            <div class="flex items-center gap-1.5 text-slate-400">
                                <span class="material-symbols-outlined text-[16px]">calendar_today</span>
                                <small class="text-xs font-semibold uppercase tracking-wider">@news.pubDate</small>
                            </div>
                            
                            <a href="@news.link" target="_blank" class="inline-flex items-center gap-1.5 px-4 py-2.5 bg-emerald-50 text-emerald-700 hover:bg-emerald-100 hover:text-emerald-800 font-bold text-xs rounded-xl transition-colors">
                                Haberi Oku
                                <span class="material-symbols-outlined text-[14px]">open_in_new</span>
                            </a>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="col-span-full text-center py-20 bg-white rounded-3xl border border-slate-100 shadow-sm">
                <span class="material-symbols-outlined text-6xl text-slate-200 mb-4 block">newspaper</span>
                <h3 class="text-xl font-bold text-slate-700">Haberler şu an yüklenemiyor.</h3>
                <p class="text-slate-500 mt-2">Lütfen daha sonra tekrar deneyin veya API limitlerinizi kontrol edin.</p>
            </div>
        }
    </div>
</div>